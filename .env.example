# OpenAI API key for the AI Coach
VITE_OPENAI_API_KEY=your_openai_api_key_here
# Optional custom API base URL (use only if needed)
# VITE_OPENAI_API_BASE_URL=https://api.openai.com/v1

# Anthropic Claude API key
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional Claude model name
VITE_ANTHROPIC_MODEL=claude-3.5-mini
# Optional custom Anthropic base URL (use only if needed)
# VITE_ANTHROPIC_API_BASE_URL=https://api.anthropic.com

# Gemini API key (Google Cloud)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
# Optional Gemini model name
VITE_GEMINI_MODEL=gemini-1.5-mini
# Optional custom Gemini base URL (use only if needed)
# VITE_GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta2

# Free LLM API key for apifreellm.com
VITE_FREE_LLM_API_KEY=your_free_llm_api_key_here
# Optional model name for free LLM provider
VITE_FREE_LLM_MODEL=apifreellm
# Optional custom Free LLM endpoint URL
# In local dev, you can use Vite proxy to avoid CORS:
# VITE_FREE_LLM_API_URL=/api/free-llm
# Otherwise use the remote URL:
# VITE_FREE_LLM_API_URL=https://apifreellm.com/api/v1/chat

# NVIDIA DeepSeek API key
VITE_NVIDIA_API_KEY=your_nvidia_api_key_here
# Optional NVIDIA base URL
# VITE_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Optional NVIDIA model name
VITE_NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro
